      >RESET DEL GIOCO - ATTENZIONE</button
    >
  </main>
</MainLayout>
<script>
  import { actions } from "astro:actions";
  import { attachPackButtonHandlers, updateAllPackButtons } from "../utils/buttonHelpers";
  import { attachControlButtonHandlers } from "../utils/controlHelpers";
  import { setupPolling } from "../utils/pollingHelpers";
  import { bumpVersion, isLatestVersion } from "../utils/requestVersion";

  // Set up polling to sync state with server
  const pollState = async () => {
    const myVersion = bumpVersion();
    const state = await actions.getsPacksState();
    if (state.data && isLatestVersion(myVersion)) {
      updateAllPackButtons(state.data);
    }
  };

  // Initialize everything when DOM is ready
  document.addEventListener("DOMContentLoaded", () => {
    attachPackButtonHandlers();
    attachControlButtonHandlers();
    setupPolling(pollState);
  });

  // Also try initialization if already loaded
  if (document.readyState === "loading") {
    // DOM still loading
  } else {
    // DOM already loaded
    attachPackButtonHandlers();
    attachControlButtonHandlers();
    setupPolling(pollState);
  }
</script>
