<script>
  import { actions } from "astro:actions";
  import { updateAllPackButtons } from "../utils/buttonHelpers";
  import type { GameState } from "../stateType";

  let currentState: GameState = {
    redPacks: [
      "closed",
      "closed",
      "closed",
      "closed",
      "closed",
      "closed",
      "closed",
      "closed",
      "closed",
      "closed",
    ],
    bluePacks: [
      "closed",
      "closed",
      "closed",
      "closed",
      "closed",
      "closed",
      "closed",
      "closed",
      "closed",
      "closed",
    ],
    currentEvent: "none",
  };

  // WebSocket — receives all state updates
  const protocol = location.protocol === "https:" ? "wss:" : "ws:";
  const ws = new WebSocket(`${protocol}//${location.host}/ws`);

  ws.onmessage = (event) => {
    currentState = JSON.parse(event.data);
    updateAllPackButtons(currentState);
  };

  ws.onclose = () => {
    setTimeout(() => location.reload(), 2000);
  };

  // Pack buttons — just fire and let WebSocket update UI
  document
    .querySelectorAll<HTMLButtonElement>("button[data-color][data-index]")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const color = btn.dataset.color as "red" | "blue";
        const index = btn.dataset.index!;
        const isOpen = btn.getAttribute("aria-disabled") === "true";
        if (isOpen) actions.closePack({ color, index });
        else actions.openPack({ color, index });
      });
    });

  document.getElementById("call")?.addEventListener("click", () => {
    actions.sendEvent("call");
  });

  document.getElementById("challenge")?.addEventListener("click", () => {
    actions.sendEvent(
      currentState.currentEvent === "challenge" ? "none" : "challenge",
    );
  });

  document.getElementById("reset")?.addEventListener("click", () => {
    actions.resetGame();
  });
</script>
